<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Daftar Buku</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 30px; }
    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
    th, td { border: 1px solid #ccc; padding: 10px; text-align: left; }
    th { background: #3498db; color: white; }
  </style>
</head>
<body>

  <a href="/">&larr; Kembali ke Katalog Utama</a>
  <h2>Daftar Buku (via Fetch API)</h2>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Judul</th>
        <th>Penulis</th>
        <th>Genre</th>
      </tr>
    </thead>
    <tbody id="books-table-body">
      <tr>
        <td colspan="4" style="text-align: center;">Memuat data dari API...</td>
      </tr>
    </tbody>
  </table>

  <script>
    // Memanggil 2 API sekaligus (/api/books DAN /api/authors)
    // Kedua request HTTP ini AKAN MUNCUL SEKALIGUS di Inspect -> Network
    Promise.all([
      fetch('/api/books').then(res => {
        if (!res.ok) throw new Error('Gagal mengambil data books');
        return res.json();
      }),
      fetch('/api/authors').then(res => {
        if (!res.ok) throw new Error('Gagal mengambil data authors');
        return res.json();
      })
    ])
    .then(([books, authors]) => {
      console.log('API Books:', books);
      console.log('API Authors:', authors);

      const tbody = document.getElementById('books-table-body');

      if (!books || books.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;">Belum ada data buku.</td></tr>';
        return;
      }

      // Render data ke tabel HTML sesuai style kamu
      tbody.innerHTML = books.map(b => {
        // Mencari nama penulis dari daftar authors berdasarkan ID (jika ada relasinya)
        const authorObj = authors.find(a => a.id === b.authorId);
        const namaPenulis = authorObj ? authorObj.name : (b.author || b.authorName || '-');

        return `
          <tr>
            <td>${b.id || '-'}</td>
            <td>${b.title || '-'}</td>
            <td>${namaPenulis}</td>
            <td>${b.genre || '-'}</td>
          </tr>
        `;
      }).join('');
    })
    .catch(err => {
      console.error('Error fetching API:', err);
      const tbody = document.getElementById('books-table-body');
      tbody.innerHTML = `
        <tr>
          <td colspan="4" style="text-align: center; color: red;">
            Gagal mengambil data dari API backend.
          </td>
        </tr>
      `;
    });
  </script>

</body>
</html>