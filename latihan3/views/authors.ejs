<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Daftar Penulis</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 30px; }
    table { width: 100%; border-collapse: collapse; margin-top: 15px; }
    th, td { border: 1px solid #ccc; padding: 10px; text-align: left; }
    th { background: #2ecc71; color: white; }
    .error-msg { color: red; margin-top: 10px; }
  </style>
</head>
<body>

  <a href="/">&larr; Kembali ke Katalog Utama</a>
  <h2>Daftar Penulis (via Fetch API)</h2>

  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Nama Penulis</th>
        <th>Asal Negara</th>
      </tr>
    </thead>
    <tbody id="authors-table-body">
      <tr>
        <td colspan="3" style="text-align: center;">Memuat data dari API...</td>
      </tr>
    </tbody>
  </table>

  <script>
    // Memanggil 2 API sekaligus (/api/authors DAN /api/books)
    // Kedua request ini akan TEREKAM BERSAMAAN di Inspect -> Network
    Promise.all([
      fetch('/api/authors').then(res => {
        if (!res.ok) throw new Error('Gagal mengambil data authors');
        return res.json();
      }),
      fetch('/api/books').then(res => {
        if (!res.ok) throw new Error('Gagal mengambil data books');
        return res.json();
      })
    ])
    .then(([authors, books]) => {
      // Kita bisa memanfaatkan data books & authors secara bersamaan di sini jika perlu
      console.log('API Authors Response:', authors);
      console.log('API Books Response:', books);

      const tbody = document.getElementById('authors-table-body');
      
      if (!authors || authors.length === 0) {
        tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;">Belum ada data penulis.</td></tr>';
        return;
      }

      // Render data ke dalam tabel sesuai style kamu
      tbody.innerHTML = authors.map(a => `
        <tr>
          <td>${a.id || '-'}</td>
          <td>${a.name || '-'}</td>
          <td>${a.country || '-'}</td>
        </tr>
      `).join('');
    })
    .catch(err => {
      console.error('Error fetching API:', err);
      const tbody = document.getElementById('authors-table-body');
      tbody.innerHTML = `
        <tr>
          <td colspan="3" style="text-align: center; color: red;">
            Gagal mengambil data dari API backend.
          </td>
        </tr>
      `;
    });
  </script>

</body>
</html>